{
  "name": "@blockmind/knowledge",
  "version": "1.0.0",
  "private": true,
  "description": "LLM-maintained knowledge base with curated external references and a filesystem-native CLI.",
  "type": "module",
  "bin": {
    "kb": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "knowledge",
    "scripts",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "CONVENTIONS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "sources:list": "tsx src/cli/index.ts sources list",
    "sources:read": "tsx src/cli/index.ts sources read"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
